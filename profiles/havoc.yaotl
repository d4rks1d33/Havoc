Teamserver {
    Host = "0.0.0.0"
    Port = 40056

    Build {
        Compiler64 = "/opt/homebrew/bin/x86_64-w64-mingw32-gcc"
        Compiler86 = "/opt/homebrew/bin/i686-w64-mingw32-gcc"
        Nasm = "/opt/homebrew/bin/nasm"
    }
}

Operators {
    user "5pider" {
        Password = "password1234"
    }

    user "Neo" {
        Password = "password1234"
    }
}

# this is optional. if you dont use it you can remove it.
Service {
    Endpoint = "service-endpoint"
    Password = "service-password"
}

Demon {
    Sleep = 2
    Jitter = 15

    TrustXForwardedFor = false

    Injection {
        Spawn64 = "C:\\Windows\\System32\\notepad.exe"
        Spawn32 = "C:\\Windows\\SysWOW64\\notepad.exe"
    }
}

# LLM Agent configuration
# Uncomment and fill in to enable the 'llm' command in agent consoles.
# The LLM runs on the teamserver side and autonomously executes commands
# on the target to achieve the operator's goal.
#
 LLM {
     Provider = "gemini"         # gemini | openai | anthropic | openrouter | ollama
     ApiKey   = ""
     Model    = "" # model name for the chosen provider
     BaseUrl  = ""               # optional: custom base URL (required for ollama/openrouter)
     MaxSteps = 20               # max iterations before stopping
     MaxTokens = 4096            # max tokens per LLM response
 }

